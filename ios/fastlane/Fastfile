require 'base64'
require 'fileutils'

default_platform(:ios)

platform :ios do
  lane :build_and_upload do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: Base64.decode64(ENV["ASC_PRIVATE_KEY_B64"]),
    )

    keychain_name = "build.keychain"
    keychain_password = "build_password"
    keychain_path = "#{Dir.home}/Library/Keychains/#{keychain_name}-db"

    create_keychain(
      name: keychain_name,
      password: keychain_password,
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false
    )

    UI.message("Deleting old Distribution certificates...")
    require 'spaceship'
    all_certs = Spaceship::ConnectAPI::Certificate.all
    dist_certs = all_certs.reject { |c| c.certificate_type.to_s.include?("DEVELOPMENT") }
    UI.message("Found #{dist_certs.count} distribution certificate(s) to delete")
    dist_certs.each do |cert|
      UI.message("Deleting: #{cert.id} (#{cert.certificate_type})")
      cert.delete!
    end

    cert(
      api_key: api_key,
      output_path: "/tmp/certs",
      keychain_path: keychain_path,
      keychain_password: keychain_password,
    )

    sigh(
      api_key: api_key,
      app_identifier: "com.alp.indirimRadariAdmin",
      output_path: "/tmp/profiles",
      force: true,
    )

    profile_uuid = lane_context[SharedValues::SIGH_UUID]
    profile_name = lane_context[SharedValues::SIGH_NAME]

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Runner.xcodeproj",
      team_id: "8J5Q5D5DB9",
      bundle_identifier: "com.alp.indirimRadariAdmin",
      code_sign_identity: "iPhone Distribution",
      profile_uuid: profile_uuid,
    )

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      configuration: "Release",
      export_method: "app-store",
      xcargs: "CODE_SIGN_STYLE=Manual DEVELOPMENT_TEAM=8J5Q5D5DB9 PROVISIONING_PROFILE='#{profile_uuid}' CODE_SIGN_IDENTITY='iPhone Distribution' CODE_SIGN_ENTITLEMENTS=Runner/Runner.entitlements",
      export_options: {
        method: "app-store",
        teamID: "8J5Q5D5DB9",
        signingStyle: "manual",
        provisioningProfiles: {
          "com.alp.indirimRadariAdmin" => profile_name
        }
      }
    )

    # --- p8 key yazma: encoding-safe, PEM validated ---
    key_id    = ENV['ASC_KEY_ID'].strip
    issuer_id = ENV['ASC_ISSUER_ID'].strip

    # Base64.decode64 → ASCII-8BIT (binary). Tüm işlemler .b ile binary modda yapılır.
    key_bytes = Base64.decode64(ENV["ASC_PRIVATE_KEY_B64"])

    # Fail-fast: boş key
    UI.user_error!("ASC_PRIVATE_KEY_B64 boş veya decode edilemedi!") if key_bytes.bytesize == 0

    # PEM format validation — .b ile encoding-agnostic karşılaştırma
    pem_header = "-----BEGIN PRIVATE KEY-----"
    pem_footer = "-----END PRIVATE KEY-----"
    unless key_bytes.b.include?(pem_header.b)
      UI.user_error!("p8 key geçersiz: PEM header bulunamadı (#{key_bytes.bytesize} bytes). Secret doğru base64 encode edildi mi?")
    end
    unless key_bytes.b.include?(pem_footer.b)
      UI.user_error!("p8 key geçersiz: PEM footer bulunamadı. Key eksik veya truncate olmuş olabilir.")
    end

    key_dir  = "#{Dir.home}/.appstoreconnect/private_keys"
    FileUtils.mkdir_p(key_dir)
    key_file = "#{key_dir}/AuthKey_#{key_id}.p8"

    # Binary mode write — ASCII-8BIT içerik dönüşümsüz yazılır
    File.open(key_file, 'wb') { |f| f.write(key_bytes) }
    File.chmod(0600, key_file)

    # Encoding-safe log: key içeriği loglanmaz, sadece boyut ve format durumu
    UI.message("p8 yazıldı: #{key_file} | #{key_bytes.bytesize} bytes | PEM format: OK")

    archive_path = lane_context[SharedValues::XCODEBUILD_ARCHIVE]

    File.write('/tmp/UploadOptions.plist', <<~PLIST)
      <?xml version="1.0" encoding="UTF-8"?>
      <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
      <plist version="1.0">
      <dict>
          <key>method</key>
          <string>app-store</string>
          <key>destination</key>
          <string>upload</string>
          <key>teamID</key>
          <string>8J5Q5D5DB9</string>
          <key>signingStyle</key>
          <string>manual</string>
          <key>provisioningProfiles</key>
          <dict>
              <key>com.alp.indirimRadariAdmin</key>
              <string>#{profile_name}</string>
          </dict>
      </dict>
      PLIST

    # -authenticationKeyPath YOK — xcodebuild ~/.appstoreconnect/private_keys/ otomatik arar
    sh("xcodebuild -exportArchive -archivePath '#{archive_path}' -exportOptionsPlist /tmp/UploadOptions.plist -exportPath /tmp/upload -authenticationKeyID '#{key_id}' -authenticationKeyIssuerID '#{issuer_id}' -allowProvisioningUpdates 2>&1")
  end
end
